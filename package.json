{
  "name": "jupyter-ntfy",
  "displayName": "Jupyter ntfy",
  "description": "Get ntfy.sh push notifications when Jupyter notebook cells finish running",
  "publisher": "mikejovyan",
  "version": "0.1.0",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikejovyan/jupyter-ntfy"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Notebooks"
  ],
  "activationEvents": [
    "onNotebook:jupyter-notebook"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Jupyter ntfy",
      "properties": {
        "jupyter-ntfy.topic": {
          "type": "string",
          "default": "",
          "description": "ntfy topic name. Pick something unique and hard to guess."
        },
        "jupyter-ntfy.priority": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "ntfy notification priority (1=min, 3=default, 5=max)."
        }
      }
    },
    "commands": [
      {
        "command": "jupyter-ntfy.toggleNotification",
        "title": "Toggle Cell Notification",
        "icon": "$(bell)"
      }
    ],
    "menus": {
      "notebook/cell/title": [
        {
          "command": "jupyter-ntfy.toggleNotification",
          "when": "notebookType == jupyter-notebook",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
